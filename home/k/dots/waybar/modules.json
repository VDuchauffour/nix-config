{
  "hyprland/workspaces": {
    "on-click": "activate",
    "active-only": false,
    "all-outputs": true,
    "format": "{}",
    "format-icons": {
      "urgent": "",
      "active": "",
      "default": ""
    },
    "persistent-workspaces": {
      "*": 5
    },
    "on-scroll-up": "hyprctl dispatch workspace e+1",
    "on-scroll-down": "hyprctl dispatch workspace e-1"
  },
  "hyprland/window": {
    "separate-outputs": true
  },
  "tray": {
    "icon-size": 18,
    "spacing": 10
  },
  "network#speed": {
    "format": "NET {bandwidthDownBits} ",
    "interval": 5,
    "tooltip-format": "{ipaddr}",
    "tooltip-format-wifi": "{essid} ({signalStrength}%) ο΅Ϊ  \n{ipaddr} | {frequency} MHz{icon} ",
    "tooltip-format-ethernet": "{ifname} σΑàÄ \n{ipaddr} | {frequency} MHz{icon} ",
    "tooltip-format-disconnected": "Not Connected to any type of Network",
    "tooltip": true
  },
  "cpu": {
    "on-click": "btop -p 2",
    "tooltip": false,
    "format": "CPU {1:}%"
  },
  "memory": {
    "format": "MEM {:2}%"
  },
  "pulseaudio": {
    "scroll-step": 1,
    "format": "{icon} {volume}%",
    "format-muted": "σΑ•¹ {volume}%",
    "format-bluetooth": "οäî {icon} {volume}%",
    "format-bluetooth-muted": "οäî σΑ•¹ {icon}",
    "format-source": "{volume}%",
    "format-source-muted": " ο³±",
    "format-icons": {
      "headphone": "οÄΞ",
      "phone": "ο²ï",
      "car": "οÜΙ",
      "default": ["σΑïΩ", "σΑ•Ä", "σΑïΨ"]
    },
    "on-click": "pwvucontrol",
    "on-click-right": "killall pwvucontrol"
  },
  "battery": {
    "format": "{icon} {capacity}%",
    "format-charging": "{icon} {capacity}% βöΓ",
    "tooltip-format": "{timeTo} | {power}w",
    "format-icons": [
      "σΑ²É",
      "σΑ²é",
      "σΑ¹Κ",
      "σΑ¹Μ",
      "σΑ¹Φ",
      "σΑ¹Ϋ",
      "σΑ¹Ψ",
      "σΑ¹Ω",
      "σΑ²Ä",
      "σΑ²¹",
      "σΑ²²",
      "σΑ¹Ι"
    ],
    "states": {
      "critical": 10,
      "warning": 25,
      "low": 50,
      "full": 100
    }
  },
  "clock": {
    "on-click": "",
    "rotate": 0,
    "timezone": "Europe/Paris",
    "format": "{:%a %d %b %H:%M}",
    "format-alt": "{ο³≥  %d¬Ζ%m¬Ζ%y}",
    "tooltip": true,
    "tooltip-format": "<span>{calendar}</span>",
    "calendar": {
      "mode": "month",
      "format": {
        "months": "<span color='#ff6699'><b>{}</b></span>",
        "days": "<span color='#cdd6f4'><b>{}</b></span>",
        "weekdays": "<span color='#7CD37C'><b>{}</b></span>",
        "today": "<span color='#ffcc66'><b>{}</b></span>"
      }
    }
  },
  "custom/notif": {
    "format": "    ",
    "on-click": "dunstctl history-pop",
    "on-click-right": "dunstctl close-all",
    "tooltip": false
  }
}
